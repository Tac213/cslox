var a = 1;

// Default case.
switch (a) {
    case 2:
        print 2;
        break;
    default:
        print "default"; // expect: default
        break;
}

a = 2;

switch (a) {
    case 1:
        print 1;
        break;
    case 2:
        print 2; // expect: 2
        break;
    default:
        print "default";
        break;
}
