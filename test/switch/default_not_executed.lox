// Tests that when a case matches and uses break, the default
// clause does NOT execute.

var a = 2;

switch (a) {
    case 1:
        print 1;
        break;
    case 2:
        print 2;  // expect: 2
        break;
    case 3:
        print 3;
        break;
    default:
        print "default";
}

print "ok";  // expect: ok
